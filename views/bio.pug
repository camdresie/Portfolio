extends layout.pug

//- Bio page showing personal background and story

block content 
  article.grid-container.portfolio-intro.portfolio-project
    .grid-x
      .cell.small-12.medium-12.large-12
        .bio-header
          .bio-photo
            img.bio-thumbnail(src='../static/images/profile_picture.jpg' alt='Cam Dresie - Knowledge & Innovation Attorney')
          .bio-title-section
            h1.about-heading Cam Dresie
            p.bio-subtitle Knowledge & Innovation Attorney | Agentic AI Builder | Product Leader

        .portfolio-content
          .skills-section
            .skills-columns
              .skills-container.ai-skills
                h6 AI & Agentic Development
                .skills-grid
                  span.skill-tag.ai-skill LangGraph
                  span.skill-tag.ai-skill LangChain
                  span.skill-tag.ai-skill Claude Agents
                  span.skill-tag.ai-skill Claude Code
                  span.skill-tag.ai-skill OpenAI Agents SDK
                  span.skill-tag.ai-skill Cursor
                  span.skill-tag.ai-skill Prompt Engineering
                  span.skill-tag.ai-skill LLM Orchestration
                  span.skill-tag.ai-skill RAG
                  span.skill-tag.ai-skill Tool Use & Function Calling
                  span.skill-tag.ai-skill Agentic AI Systems
                  span.skill-tag.ai-skill MCP
                  span.skill-tag.ai-skill Human-in-the-Loop Design
                  span.skill-tag.ai-skill Microsoft Copilot Studio
                  span.skill-tag.ai-skill AI Evals

              .skills-container.product-skills
                h6 Product Management
                .skills-grid
                  span.skill-tag.product-skill Product Strategy
                  span.skill-tag.product-skill Portfolio Management
                  span.skill-tag.product-skill Team Leadership
                  span.skill-tag.product-skill People Management
                  span.skill-tag.product-skill Cross-functional Leadership
                  span.skill-tag.product-skill Stakeholder Management
                  span.skill-tag.product-skill AI/ML Product Development
                  span.skill-tag.product-skill AI Vendor Evaluation
                  span.skill-tag.product-skill Legal Tech
                  span.skill-tag.product-skill Knowledge Management
                  span.skill-tag.product-skill Enterprise SaaS
                  span.skill-tag.product-skill User Research
                  span.skill-tag.product-skill Agile Methodologies
                  span.skill-tag.product-skill Go-to-Market Strategy
                  span.skill-tag.product-skill OKRs & KPIs

              .skills-container.engineering-skills
                h6 Engineering & Technical
                .skills-grid
                  span.skill-tag.engineering-skill Python
                  span.skill-tag.engineering-skill JavaScript
                  span.skill-tag.engineering-skill Java
                  span.skill-tag.engineering-skill Swift
                  span.skill-tag.engineering-skill React.js
                  span.skill-tag.engineering-skill Vue.js
                  span.skill-tag.engineering-skill Node.js
                  span.skill-tag.engineering-skill SQL/MySQL
                  span.skill-tag.engineering-skill Azure Cloud
                  span.skill-tag.engineering-skill REST APIs
                  span.skill-tag.engineering-skill Git
                  span.skill-tag.engineering-skill CI/CD
                  span.skill-tag.engineering-skill System Design

          .portfolio-bio
            p
              | As Senior Knowledge & Innovation Attorney at Paul Weiss, I bring a product manager's mindset to legal innovation: building AI-enabled solutions that turn complex problems into shipped, impactful tools for the lawyers and clients we serve. I believe great products — legal or otherwise — come from high-trust teams with clear outcomes and room to create.
            p
              | I invest in people: candid feedback, visible expectations, and coaching are baked into how I work. The result is a culture that experiments, has freedom to fail, learns quickly, and consistently delivers impact. Known for my collaborative leadership style and clear communication, I help translate ambitious legal and business goals into practical solutions that exceed expectations.
            p
              | My technical acumen, paired with a background spanning law and product, lets me navigate complex challenges with a unique edge in shaping strategy. I stay hands-on with agentic AI — designing RAG architectures and multi-step, tool-using workflows where LLMs autonomously reason, plan, and execute — bridging product strategy and engineering in a way few legal innovators can.
            p
              | With deep experience supporting private fund sponsors and their counsel, I focus on the workflows that matter most to funds practitioners, from fund formation and side letter negotiation to portfolio company management and LP relations. Whether evaluating an AI vendor, designing a new workflow, or partnering with practice groups on knowledge initiatives, I bring transparency, innovation, and a relentless pursuit of excellence.
            p
              | Outside the office, I'm an avid hiker, runner, and reader, with a particular fondness for Walter Isaacson's biography of Leonardo Da Vinci. I also love spending time with my husband, attending concerts, and spending quality time with our family Labradoodle, Koda.

  script.
    document.addEventListener('DOMContentLoaded', function() {
      const inlineStyles = `
        .about-heading {
          margin-bottom: 0.5rem;
          font-weight: 600;
          color: #fff;
          letter-spacing: 0.5px;
        }

        .portfolio-bio {
          background: rgba(255, 255, 255, 0.03);
          border-radius: 8px;
          padding: 30px;
          box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
          border: 1px solid rgba(255, 255, 255, 0.05);
          margin-bottom: 20px;
        }

        .portfolio-bio p {
          margin-bottom: 1.5rem;
          line-height: 1.7;
          color: rgba(255, 255, 255, 0.85);
          max-width: 100%;
          border-bottom: none;
          padding-bottom: 0;
        }

        .portfolio-bio p:last-child {
          margin-bottom: 0;
        }

        .skills-section {
          margin-top: 0.5rem;
          margin-bottom: 20px;
        }

        .skills-columns {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 16px;
        }

        @media (max-width: 768px) {
          .skills-columns {
            grid-template-columns: 1fr;
          }
        }

        .skills-container {
          background: rgba(255, 255, 255, 0.03);
          border-radius: 8px;
          padding: 16px;
          box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
          border: 1px solid rgba(255, 255, 255, 0.05);
        }

        .skills-container.product-skills {
          border-top: 3px solid #00a6ff;
        }

        .skills-container.engineering-skills {
          border-top: 3px solid #00cc66;
        }

        .skills-container.ai-skills {
          border-top: 3px solid #a855f7;
        }

        .skills-container h6 {
          margin-bottom: 12px;
          font-weight: 600;
          color: #fff;
          letter-spacing: 0.5px;
          font-size: 0.85rem;
          display: flex;
          align-items: center;
        }

        .skills-container.product-skills h6::before {
          content: "\\1F468\\200D\\1F4BC";
          margin-right: 8px;
          font-size: 1rem;
        }

        .skills-container.engineering-skills h6::before {
          content: "\\1F468\\200D\\1F4BB";
          margin-right: 8px;
          font-size: 1rem;
        }

        .skills-container.ai-skills h6::before {
          content: "\\1F916";
          margin-right: 8px;
          font-size: 1rem;
        }

        .skills-grid {
          display: flex;
          flex-wrap: wrap;
          gap: 6px;
        }

        .skill-tag {
          padding: 4px 10px;
          border-radius: 4px;
          font-size: 0.75rem;
          font-weight: 500;
          transition: all 0.3s ease;
          cursor: default;
        }

        .skill-tag.product-skill {
          background: rgba(0, 166, 255, 0.1);
          color: rgba(255, 255, 255, 0.9);
          border: 1px solid rgba(0, 166, 255, 0.2);
        }

        .skill-tag.product-skill:hover {
          background: rgba(0, 166, 255, 0.2);
          transform: translateY(-1px);
        }

        .skill-tag.engineering-skill {
          background: rgba(0, 204, 102, 0.1);
          color: rgba(255, 255, 255, 0.9);
          border: 1px solid rgba(0, 204, 102, 0.2);
        }

        .skill-tag.engineering-skill:hover {
          background: rgba(0, 204, 102, 0.2);
          transform: translateY(-1px);
        }

        .skill-tag.ai-skill {
          background: rgba(168, 85, 247, 0.1);
          color: rgba(255, 255, 255, 0.9);
          border: 1px solid rgba(168, 85, 247, 0.2);
        }

        .skill-tag.ai-skill:hover {
          background: rgba(168, 85, 247, 0.2);
          transform: translateY(-1px);
        }
      `;

      const styleElement = document.createElement('style');
      styleElement.textContent = inlineStyles;
      document.head.appendChild(styleElement);
    });